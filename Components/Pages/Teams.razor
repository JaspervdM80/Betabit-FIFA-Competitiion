@page "/"
@using FC26Competition.Models
@using FC26Competition.Services
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer

<div class="page-header">
    <h1 class="page-title">⚽ Teams Management</h1>
    <p class="page-description">Create and manage your 8 teams for the FC26 Competition</p>
</div>

@if (teams.Count < 8)
{
    <div class="alert alert-info">
        <span>📋</span>
        <span>You have @teams.Count/8 teams. @(8 - teams.Count) more needed to start the competition.</span>
    </div>
}
else
{
    <div class="alert alert-success">
        <span>✅</span>
        <span>All 8 teams registered! You can now generate the competition fixtures.</span>
    </div>
}

<div class="flex-between mb-3">
    <button class="btn btn-primary" @onclick="ShowAddModal" disabled="@(teams.Count >= 8)">
        ➕ Add Team
    </button>
</div>

<div class="grid grid-2">
    @foreach (var team in teams)
    {
        <div class="team-card">
            <h3 class="team-name">@team.TeamName</h3>
            <div class="team-info">
                <strong>Players:</strong> @team.Player1Name & @team.Player2Name
            </div>
            <span class="team-club">@team.ClubCountry</span>
            <div class="team-actions">
                <button class="btn btn-secondary" @onclick="() => ShowEditModal(team)">
                    ✏️ Edit
                </button>
                <button class="btn btn-danger" @onclick="() => DeleteTeamAsync(team.Id)">
                    🗑️ Delete
                </button>
            </div>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="HideModal">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(editingTeam == null ? "Add Team" : "Edit Team")</h2>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Team Name</label>
                    <input type="text" class="form-control" @bind="teamName" placeholder="e.g., The Legends" />
                </div>
                <div class="form-group">
                    <label class="form-label">Player 1 Name</label>
                    <input type="text" class="form-control" @bind="player1Name" placeholder="e.g., John Doe" />
                </div>
                <div class="form-group">
                    <label class="form-label">Player 2 Name</label>
                    <input type="text" class="form-control" @bind="player2Name" placeholder="e.g., Jane Smith" />
                </div>
                <div class="form-group">
                    <label class="form-label">Club/Country</label>
                    <input type="text" class="form-control" @bind="clubCountry" placeholder="e.g., FC Barcelona, Netherlands" />
                </div>
                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-warning">
                        <span>⚠️</span>
                        <span>@errorMessage</span>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="HideModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveTeamAsync">
                    @(editingTeam == null ? "Add Team" : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}

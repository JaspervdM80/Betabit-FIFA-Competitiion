@page "/display"
@using FC26Competition.Models
@using FC26Competition.Services
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>FC26 Competition - Live Display</PageTitle>

<div class="display-container">
    <div class="display-header">
        <h1 class="display-title">⚽ FC26 COMPETITION @DateTime.Now.Year</h1>
        <div class="current-time">@currentTime.ToString("HH:mm:ss")</div>
    </div>

    <div class="display-content tables-fixtures-grid">
        <!-- Row 1: Group A standings + Group A fixtures -->
        <div class="grid-item">
            <div class="group-standings">
                <h3 class="group-title">🔵 GROUP A</h3>
                <table class="standings-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Team</th>
                            <th>P</th>
                            <th>W</th>
                            <th>D</th>
                            <th>L</th>
                            <th>GD</th>
                            <th>PTS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var groupAStandings = CompetitionService.GetGroupStandings(teams, GroupName.GroupA);
                            int pos = 1;
                        }
                        @foreach (var team in groupAStandings)
                        {
                            <tr class="@(pos <= 2 ? "qualify-cl" : "qualify-el")">
                                <td class="pos">@pos</td>
                                <td class="team-cell">@team.TeamName</td>
                                <td>@team.Played</td>
                                <td>@team.Won</td>
                                <td>@team.Drawn</td>
                                <td>@team.Lost</td>
                                <td>@team.GoalDifference</td>
                                <td class="pts">@team.Points</td>
                            </tr>
                            pos++;
                        }
                    </tbody>
                </table>
            </div>
            <div class="legend compact-legend">
                <span class="legend-item"><span class="legend-cl">█</span> Top 2 → Champions League</span>
                <span class="legend-item"><span class="legend-el">█</span> Bottom 2 → Europa League</span>
            </div>
        </div>
        <div class="grid-item">
            <h3 class="group-title fixtures-title">📅 GROUP A FIXTURES</h3>
            <div class="compact-fixtures">
                @foreach (var match in allMatches
                    .Where(m => m.Stage == MatchStage.GroupStage && m.GroupName == GroupName.GroupA)
                    .OrderBy(m => m.ScheduledTime)
                    .Take(8))
                {
                    var homeTeam = GetTeam(match.HomeTeamId);
                    var awayTeam = GetTeam(match.AwayTeamId);
                    if (homeTeam == null || awayTeam == null) { continue; }
                    <div class="fixture-row">
                        <span class="fixture-time">@match.ScheduledTime?.ToString("HH:mm")</span>
                        <span class="fixture-teams">
                            @homeTeam.TeamName <span class="vs-small">vs</span> @awayTeam.TeamName
                            @if (match.IsPlayed || (match.HomeScore.HasValue && match.AwayScore.HasValue))
                            {
                                <span class="fixture-score">@match.HomeScore - @match.AwayScore</span>
                            }
                        </span>
                        <span class="fixture-screen screen-@match.ScreenNumber">Screen @match.ScreenNumber</span>
                    </div>
                }
            </div>
        </div>

        <!-- Row 2: Group B standings + Group B fixtures -->
        <div class="grid-item">
            <div class="group-standings">
                <h3 class="group-title">🟠 GROUP B</h3>
                <table class="standings-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Team</th>
                            <th>P</th>
                            <th>W</th>
                            <th>D</th>
                            <th>L</th>
                            <th>GD</th>
                            <th>PTS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var groupBStandings = CompetitionService.GetGroupStandings(teams, GroupName.GroupB);
                            int posB = 1;
                        }
                        @foreach (var team in groupBStandings)
                        {
                            <tr class="@(posB <= 2 ? "qualify-cl" : "qualify-el")">
                                <td class="pos">@posB</td>
                                <td class="team-cell">@team.TeamName</td>
                                <td>@team.Played</td>
                                <td>@team.Won</td>
                                <td>@team.Drawn</td>
                                <td>@team.Lost</td>
                                <td>@team.GoalDifference</td>
                                <td class="pts">@team.Points</td>
                            </tr>
                            posB++;
                        }
                    </tbody>
                </table>
            </div>
            <div class="legend compact-legend">
                <span class="legend-item"><span class="legend-cl">█</span> Top 2 → Champions League</span>
                <span class="legend-item"><span class="legend-el">█</span> Bottom 2 → Europa League</span>
            </div>
        </div>
        <div class="grid-item">
            <h3 class="group-title fixtures-title">📅 GROUP B FIXTURES</h3>
            <div class="compact-fixtures">
                @foreach (var match in allMatches
                    .Where(m => m.Stage == MatchStage.GroupStage && m.GroupName == GroupName.GroupB)
                    .OrderBy(m => m.ScheduledTime)
                    .Take(8))
                {
                    var homeTeam = GetTeam(match.HomeTeamId);
                    var awayTeam = GetTeam(match.AwayTeamId);
                    if (homeTeam == null || awayTeam == null) { continue; }
                    <div class="fixture-row">
                        <span class="fixture-time">@match.ScheduledTime?.ToString("HH:mm")</span>
                        <span class="fixture-teams">
                            @homeTeam.TeamName <span class="vs-small">vs</span> @awayTeam.TeamName
                            @if (match.IsPlayed || (match.HomeScore.HasValue && match.AwayScore.HasValue))
                            {
                                <span class="fixture-score">@match.HomeScore - @match.AwayScore</span>
                            }
                        </span>
                        <span class="fixture-screen screen-@match.ScreenNumber">Screen @match.ScreenNumber</span>
                    </div>
                }
            </div>
        </div>

        <!-- Knockout fixtures full width with meta aligned left/center/right -->
        @if (knockoutMatches.Any())
        {
            <div class="grid-item span-2">
                <h3 class="group-title fixtures-title">🏆 Knockout Fixtures</h3>
                <div class="compact-fixtures knockout-fullwidth">
                    @foreach (var match in knockoutMatches.OrderBy(m => m.ScheduledTime))
                    {
                        var homeTeam = match.HomeTeamId != Guid.Empty ? GetTeam(match.HomeTeamId) : null;
                        var awayTeam = match.AwayTeamId != Guid.Empty ? GetTeam(match.AwayTeamId) : null;
                        var leagueClass = match.LeagueType == LeagueType.ChampionsLeague ? "cl-badge" : "el-badge";
                        var finalClass = match.KnockoutRound == KnockoutRound.Final ? "final-glow" : null;
                        <div class="fixture-row two-line knockout-card @finalClass">
                            <div class="fixture-meta knockout-meta">
                                <span class="fixture-time">@match.ScheduledTime?.ToString("HH:mm")</span>
                                <span class="knockout-badge @leagueClass">@match.LeagueType - @match.KnockoutRound</span>
                                <span class="fixture-screen screen-@match.ScreenNumber">Screen @match.ScreenNumber</span>
                            </div>
                            <div class="fixture-teams">@(homeTeam?.TeamName ?? "TBD") <span class="vs-small">vs</span> @(awayTeam?.TeamName ?? "TBD")
                                @if (match.IsPlayed || (match.HomeScore.HasValue && match.AwayScore.HasValue))
                                {
                                    <span class="fixture-score">@match.HomeScore - @match.AwayScore</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

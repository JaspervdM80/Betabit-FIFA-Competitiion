@page "/setup"
@using FC26Competition.Models
@using FC26Competition.Services
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer

<div class="page-header">
    <h1 class="page-title">🎮 Competition Setup</h1>
    <p class="page-description">Generate random groups and competition schedule</p>
</div>

@if (teams.Count < 8)
{
    <div class="alert alert-warning">
        <span>⚠️</span>
        <span>Please register 8 teams before setting up the competition. Current teams: @teams.Count/8</span>
    </div>
    <button class="btn btn-primary" @onclick="GoToTeams">
        Go to Teams Management
    </button>
}
else
{
    @if (!groupsGenerated)
    {
        <div class="card">
            <h2 style="margin-bottom: 1.5rem; color: var(--electric-blue);">🎲 Generate Competition</h2>
            
            <p style="margin-bottom: 1.5rem; font-size: 1.1rem;">
                This will automatically:
            </p>
            <ul style="margin-bottom: 2rem; font-size: 1.05rem; line-height: 1.8;">
                <li>✅ Randomly assign 8 teams into 2 groups (4 teams each)</li>
                <li>✅ Generate group stage fixtures (12 matches - 6 rounds)</li>
                <li>✅ Generate knockout fixtures (6 matches - 3 rounds)</li>
                <li>✅ Schedule matches on 2 screens simultaneously</li>
            </ul>

            <div class="form-group" style="max-width: 300px;">
                <label class="form-label">Start Time</label>
                <input type="time" class="form-control" @bind-value="startTimeInput" @bind-value:format="HH:mm" />
                <div class="mt-2" style="font-size: 0.9rem; color: var(--text-secondary);">
                    Group Stage: 6 rounds × 15 min = 1h 30min<br/>
                    Break: 15 minutes<br/>
                    Knockout: 3 rounds × 15 min = 45min<br/>
                    <strong>Total duration: ~2h 30min</strong>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-warning mt-3">
                    <span>⚠️</span>
                    <span>@errorMessage</span>
                </div>
            }

            <div class="mt-4 flex gap-2">
                <button class="btn btn-primary btn-large" @onclick="GenerateCompetition">
                    🚀 Generate Competition
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <h2 style="margin-bottom: 1.5rem; color: var(--neon-green);">✅ Competition Generated!</h2>
            
            <div class="grid grid-2 mb-4">
                <div class="group-display">
                    <h3 style="color: var(--champions-blue); margin-bottom: 1rem;">🔵 Group A</h3>
                    <ul>
                        @foreach (var team in teams.Where(t => t.GroupName == GroupName.GroupA))
                        {
                            <li>@team.TeamName</li>
                        }
                    </ul>
                </div>
                <div class="group-display">
                    <h3 style="color: var(--europa-orange); margin-bottom: 1rem;">🟠 Group B</h3>
                    <ul>
                        @foreach (var team in teams.Where(t => t.GroupName == GroupName.GroupB))
                        {
                            <li>@team.TeamName</li>
                        }
                    </ul>
                </div>
            </div>

            <div style="margin-top: 2rem;">
                <p style="font-size: 1.1rem; margin-bottom: 1rem;">
                    <strong>Start Time:</strong> @startTimeInput
                </p>
                <p style="font-size: 1.05rem; color: var(--text-secondary);">
                    All fixtures have been generated with matches scheduled on both screens!
                </p>
            </div>

            <div class="mt-4 flex gap-2">
                <button class="btn btn-primary" @onclick="GoToAdmin">
                    Go to Admin Panel
                </button>
                <a class="btn btn-secondary" href="/display" target="_blank">
                    Open Display Screen
                </a>
                <button class="btn btn-danger" @onclick="RegenerateCompetition">
                    🔄 Regenerate
                </button>
            </div>
        </div>
    }
}

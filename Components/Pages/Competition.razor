@page "/competition"
@using FC26Competition.Models
@using FC26Competition.Services
@inject CompetitionService CompetitionService
@implements IDisposable
@rendermode InteractiveServer

<div class="page-header">
    <h1 class="page-title">🏆 Main Competition</h1>
    <p class="page-description">Round-robin tournament - every team plays every other team once</p>
</div>

@if (teams.Count < 16)
{
    <div class="alert alert-warning">
        <span>⚠️</span>
        <span>Please register 16 teams before generating the competition.</span>
    </div>
}
else
{
    <div class="flex-between mb-3">
        <button class="btn btn-primary" @onclick="GenerateFixtures" disabled="@(matches.Count > 0)">
            🎲 Generate Fixtures
        </button>
        @if (AllMatchesPlayed() && matches.Count > 0)
        {
            <button class="btn btn-champions" @onclick="SplitCompetition">
                ⚡ Split into Champions & Europa League
            </button>
        }
    </div>

    @if (matches.Count > 0)
    {
        <div class="alert alert-info mb-3">
            <span>📊</span>
            <span>
                Matches Played: @matches.Count(m => m.IsPlayed)/@matches.Count
                @if (AllMatchesPlayed())
                {
                    <strong> - All matches complete! Ready to split leagues.</strong>
                }
            </span>
        </div>

        <div class="grid grid-2">
            <!-- League Table -->
            <div>
                <div class="table-container league-table">
                    <div class="league-table-header">
                        📊 League Standings
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th class="table-position">#</th>
                                <th>Team</th>
                                <th class="table-stats">P</th>
                                <th class="table-stats">W</th>
                                <th class="table-stats">D</th>
                                <th class="table-stats">L</th>
                                <th class="table-stats">GF</th>
                                <th class="table-stats">GA</th>
                                <th class="table-stats">GD</th>
                                <th class="table-stats">Pts</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var position = 1;
                            }
                            @foreach (var team in GetSortedTeams())
                            {
                                var rowClass = position <= 4 ? "champions-position" : position > 12 ? "europa-position" : "";
                                <tr class="@rowClass">
                                    <td class="table-position">@position</td>
                                    <td class="table-team">@team.TeamName</td>
                                    <td class="table-stats">@team.Played</td>
                                    <td class="table-stats">@team.Won</td>
                                    <td class="table-stats">@team.Drawn</td>
                                    <td class="table-stats">@team.Lost</td>
                                    <td class="table-stats">@team.GoalsFor</td>
                                    <td class="table-stats">@team.GoalsAgainst</td>
                                    <td class="table-stats">@team.GoalDifference</td>
                                    <td class="table-stats"><strong>@team.Points</strong></td>
                                </tr>
                                position++;
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-2" style="font-size: 0.9rem; color: var(--text-secondary);">
                    <div style="display: flex; gap: 1rem; align-items: center;">
                        <span style="display: flex; align-items: center; gap: 0.5rem;">
                            <span style="width: 12px; height: 12px; background: var(--champions-color); border-radius: 2px;"></span>
                            Top 4 → Champions League
                        </span>
                        <span style="display: flex; align-items: center; gap: 0.5rem;">
                            <span style="width: 12px; height: 12px; background: var(--europa-color); border-radius: 2px;"></span>
                            Bottom 4 → Europa League
                        </span>
                    </div>
                </div>
            </div>

            <!-- Fixtures -->
            <div>
                <div class="card">
                    <h3 style="margin-bottom: 1rem; color: var(--primary-color);">⚽ Fixtures & Results</h3>
                    <div style="max-height: 600px; overflow-y: auto;">
                        @foreach (var match in matches.OrderBy(m => m.IsPlayed))
                        {
                            var homeTeam = GetTeam(match.HomeTeamId);
                            var awayTeam = GetTeam(match.AwayTeamId);
                            if (homeTeam != null && awayTeam != null)
                            {
                                <div class="match-card">
                                    <div class="match-team">@homeTeam.TeamName</div>
                                    @if (!match.IsPlayed)
                                    {
                                        <div class="match-score">
                                            <input type="number" 
                                                   class="match-score-input" 
                                                   min="0" 
                                                   @bind="@homeScores[match.Id]" 
                                                   placeholder="0" />
                                            <span class="match-vs">vs</span>
                                            <input type="number" 
                                                   class="match-score-input" 
                                                   min="0" 
                                                   @bind="@awayScores[match.Id]" 
                                                   placeholder="0" />
                                            <button class="btn btn-primary" 
                                                    style="padding: 0.5rem 1rem; margin-left: 0.5rem;"
                                                    @onclick="() => SaveMatchResult(match)">
                                                Save
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="match-score">
                                            <strong>@match.HomeScore</strong>
                                            <span class="match-vs">-</span>
                                            <strong>@match.AwayScore</strong>
                                            <button class="btn btn-secondary" 
                                                    style="padding: 0.5rem 1rem; margin-left: 0.5rem; font-size: 0.9rem;"
                                                    @onclick="() => EditMatchResult(match)">
                                                ✏️
                                            </button>
                                        </div>
                                    }
                                    <div class="match-team" style="text-align: right;">@awayTeam.TeamName</div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    .champions-position {
        background: rgba(0, 102, 204, 0.05);
        border-left: 3px solid var(--champions-color);
    }

    .europa-position {
        background: rgba(255, 102, 0, 0.05);
        border-left: 3px solid var(--europa-color);
    }
</style>

@code {
    private List<Team> teams = new();
    private List<Match> matches = new();
    private Dictionary<Guid, int> homeScores = new();
    private Dictionary<Guid, int> awayScores = new();

    protected override void OnInitialized()
    {
        LoadData();
        CompetitionService.OnChange += OnDataChanged;
    }

    private void LoadData()
    {
        teams = CompetitionService.GetAllTeams().ToList();
        matches = CompetitionService.GetMainCompetitionMatches().ToList();
        InitializeScoreDictionaries();
    }

    private void OnDataChanged()
    {
        InvokeAsync(() =>
        {
            LoadData();
            StateHasChanged();
        });
    }

    private void InitializeScoreDictionaries()
    {
        homeScores.Clear();
        awayScores.Clear();
        foreach (var match in matches)
        {
            homeScores[match.Id] = match.HomeScore ?? 0;
            awayScores[match.Id] = match.AwayScore ?? 0;
        }
    }

    private void GenerateFixtures()
    {
        try
        {
            CompetitionService.GenerateMainCompetitionFixtures();
            LoadData();
        }
        catch (Exception ex)
        {
            // Handle error
        }
    }

    private void SaveMatchResult(Match match)
    {
        if (homeScores.TryGetValue(match.Id, out var homeScore) &&
            awayScores.TryGetValue(match.Id, out var awayScore))
        {
            CompetitionService.UpdateMatchResult(match.Id, homeScore, awayScore);
        }
    }

    private void EditMatchResult(Match match)
    {
        if (match.HomeScore.HasValue && match.AwayScore.HasValue)
        {
            homeScores[match.Id] = match.HomeScore.Value;
            awayScores[match.Id] = match.AwayScore.Value;
            match.HomeScore = null;
            match.AwayScore = null;
        }
    }

    private void SplitCompetition()
    {
        try
        {
            CompetitionService.SplitCompetition();
        }
        catch (Exception ex)
        {
            // Handle error
        }
    }

    private Team? GetTeam(Guid teamId) => teams.FirstOrDefault(t => t.Id == teamId);

    private List<Team> GetSortedTeams() => CompetitionService.GetLeagueStandings();

    private bool AllMatchesPlayed() => matches.Count > 0 && matches.All(m => m.IsPlayed);

    public void Dispose()
    {
        CompetitionService.OnChange -= OnDataChanged;
    }
}
